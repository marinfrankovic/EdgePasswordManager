@* Root HTML document for the Blazor Server app. *@
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edge Password Bulk Manager</title>
    <base href="/" />
    <link rel="stylesheet" href="css/app.css" />
    <link rel="icon" href="data:," />
    <HeadOutlet />
</head>
<body>
    <Routes />
    <div id="blazor-error-ui">
        An unhandled error has occurred.
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>
    <script src="_framework/blazor.web.js"></script>
    <script>
        window.epmDownload = (fileName, contentType, base64) => {
            const link = document.createElement('a');
            link.download = fileName;
            link.href = `data:${contentType};base64,${base64}`;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        };
        window.epmCopy = async (text) => {
            try { await navigator.clipboard.writeText(text); return true; }
            catch { return false; }
        };
        window.epmToggleTheme = (theme) => {
            document.documentElement.setAttribute('data-theme', theme);
        };
        window.epmGetAutoUpdateCheck = () => localStorage.getItem('epm-auto-update-check') === 'true';
        window.epmSetAutoUpdateCheck = (enabled) => localStorage.setItem('epm-auto-update-check', enabled ? 'true' : 'false');
    </script>
</body>
</html>
