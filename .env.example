# Copy this file to ".env" and adjust for your machine.
#
# Path to your Edge "User Data" directory.
# Windows (Docker Desktop / WSL2), use the full Windows path:
#   EDGE_USER_DATA=C:\Users\<you>\AppData\Local\Microsoft\Edge\User Data
# Edge Beta:  ...\Microsoft\Edge Beta\User Data
# Edge Dev:   ...\Microsoft\Edge Dev\User Data
# Linux:      /home/<you>/.config/microsoft-edge
EDGE_USER_DATA=C:\Users\<you>\AppData\Local\Microsoft\Edge\User Data

# Host port to expose the web UI on (http://localhost:HOST_PORT).
HOST_PORT=8088

# Set to true to disable all delete/backup/restore writes (read-only preview).
READ_ONLY=false
