# Copy this file to ".env" and adjust for your machine.
#
# Path to your Edge "User Data" directory.
# Windows (Docker Desktop / WSL2), use the full Windows path:
#   EDGE_USER_DATA=C:\Users\<you>\AppData\Local\Microsoft\Edge\User Data
# Edge Beta:  ...\Microsoft\Edge Beta\User Data
# Edge Dev:   ...\Microsoft\Edge Dev\User Data
# Linux:      /home/<you>/.config/microsoft-edge
EDGE_USER_DATA=C:\Users\<you>\AppData\Local\Microsoft\Edge\User Data

# Host address and port for the web UI. Keep loopback unless a trusted firewall protects the port.
BIND_ADDRESS=127.0.0.1
HOST_PORT=8088

# Safe defaults: application writes are disabled and Edge data is mounted read-only.
# To enable delete/backup/restore, explicitly set READ_ONLY=false and EDGE_MOUNT_MODE=rw.
READ_ONLY=true
EDGE_MOUNT_MODE=ro
